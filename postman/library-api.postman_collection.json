    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"API Tester\",\n  \"email\": \"tester+{{$timestamp}}@example.com\",\n  \"password\": \"Test@123456789\",\n  \"password_confirmation\": \"Test@123456789\"\n}"
            },
            "url": {
              "raw": "{{apiV1}}/auth/register",
              "host": [
                "{{apiV1}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@library.local\",\n  \"password\": \"ChangeMe@12345\"\n}"
            },
            "url": {
              "raw": "{{apiV1}}/auth/login",
              "host": [
                "{{apiV1}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Token is returned', function () {",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('Roles and permissions are present', function () {",
                  "  pm.expect(data.roles).to.be.an('array');",
                  "  pm.expect(data.permissions).to.be.an('array');",
                  "});",
                  "if (data.token) {",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Me endpoint succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Me response has user object', function () {",
                  "  pm.expect(data.user).to.be.an('object');",
                  "  pm.expect(data.user.email).to.exist;",
                  "});",
                  "pm.test('Me response has RBAC data', function () {",
                  "  pm.expect(data.roles).to.be.an('array');",
                  "  pm.expect(data.permissions).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
