          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('List books succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Books pagination metadata exists', function () {",
                  "  pm.expect(json.meta).to.be.an('object');",
                  "  pm.expect(json.meta.current_page).to.be.a('number');",
                  "  pm.expect(json.meta.per_page).to.be.a('number');",
                  "});",
                  "pm.test('Books data is an array', function () {",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
