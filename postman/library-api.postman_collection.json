{
  "info": {
    "name": "Library API - Laravel 13",
    "description": "Postman collection for versioned Laravel Library API (Sanctum auth).\n\nFlow:\n1) Register or Login\n2) Token auto-saved to {{token}}\n3) Run protected CRUD requests for Authors/Categories/Books/Members/Loans\n\nNotes:\n- Base URL defaults to http://127.0.0.1:8000\n- IDs are auto-saved from create requests into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a87ea203-f11f-46e8-a766-e4ecf40704af"
  },
